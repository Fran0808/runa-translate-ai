# Puerto en el que correrá el servidor FastAPI (Por defecto: 8000)
PORT=8000

# Conexión a MongoDB Atlas
# Reemplaza con tu URI real de MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/runatranslate?retryWrites=true&w=majority

# Token de API de Hugging Face (Opcional - Útil para Whisper ASR y descargas rápidas)
# Crea una cuenta en huggingface.co y obtén tu token gratuito en Settings -> Access Tokens (Rol: Read)
HF_API_TOKEN=tu_token_de_hugging_face_aqui

# Entorno de ejecución (development / production)
ENV_MODE=development
